# Meraki API key — get from Meraki Dashboard > My Profile > API access
MERAKI_API_KEY=your_meraki_api_key_here

# Google Chat webhook for alerts (optional)
# GOOGLE_CHAT_WEBHOOK=https://chat.googleapis.com/v1/spaces/...

# Performance score threshold to trigger alert (0–100, default: 75)
ALERT_THRESHOLD=75

# Minutes between repeat alerts for the same device (default: 30)
REMINDER_INTERVAL=30

# Send startup notification (true/false, default: false)
TRACKING=false

# Meraki device serial numbers — prefix SERIAL_ followed by a label
SERIAL_HN=XXXX-XXXX-XXXX
SERIAL_HCM=YYYY-YYYY-YYYY
# SERIAL_DEVICE3=ZZZZ-ZZZZ-ZZZZ
